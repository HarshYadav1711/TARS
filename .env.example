# Clerk – get keys at https://dashboard.clerk.com (free tier).
# Omit to run the app without auth; add both when you need sign-in/sign-up.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Convex – run `npx convex dev` once to create a project and get this URL.
# Omit to run the app without Convex; add when you need database/realtime.
NEXT_PUBLIC_CONVEX_URL=

# Convex Dashboard (Settings → Environment Variables): set for Convex backend to accept Clerk JWTs.
# Copy the Issuer URL from Clerk Dashboard → JWT Templates → "convex" template.
# Required for Convex auth (profile sync, etc.) when using Clerk.
# CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-issuer.clerk.accounts.dev
