# Clerk – get keys at https://dashboard.clerk.com (free tier).
# Omit to run the app without auth; add both when you need sign-in/sign-up.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Convex – run `npx convex dev` once to create a project and get this URL.
# Omit to run the app without Convex; add when you need database/realtime.
NEXT_PUBLIC_CONVEX_URL=
